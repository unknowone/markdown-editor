{
  "name": "markdown-editor",
  "version": "1.0.0",
  "description": "A personal Markdown editor for macOS",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "node node_modules/vite/bin/vite.js",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "node node_modules/vite/bin/vite.js build && electron-builder",
    "preview": "node node_modules/vite/bin/vite.js preview"
  },
  "keywords": ["markdown", "editor", "electron", "macos"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "vite": "^5.3.4",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "highlight.js": "^11.10.0",
    "lucide-react": "^0.414.0",
    "marked": "^13.0.0",
    "marked-highlight": "^2.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.personal.markdown-editor",
    "productName": "Markdown Editor",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
